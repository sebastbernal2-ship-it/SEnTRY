# S.E.N.T.R.Y. Environment Variables
# Copy this to .env and fill in your details

# Alchemy API Key for EVM Ingestion
ALCHEMY_API_KEY=your_alchemy_api_key_here

# The target wallet address to ingest history from
# Example: 0xAb5801a7D398351b8bE11C439e05C5B3259aeC9B (Vitalik's address - use for testing only)
TARGET_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Chain Configuration (Default: eth-mainnet)
# Options: eth-mainnet, polygon-mainnet, base-mainnet, etc.
ALCHEMY_NETWORK=eth-mainnet

# Data Configuration
USE_REAL_DATA=True
DATA_PATH=data/transactions_real.csv
